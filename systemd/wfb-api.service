[Unit]
Description=WFB FastAPI service
After=network-online.target
Wants=network-online.target

[Service]
User=pi
Group=pi
WorkingDirectory=/opt/visr
Environment="PATH=/opt/visr/venv/bin"
ExecStart=/opt/visr/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
